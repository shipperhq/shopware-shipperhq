<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <imports>
        <import resource="../src/Feature/ConfigurationHandler/Resources/config/services.xml"/>
        <import resource="../src/Feature/ProductData/Resources/config/services.xml"/>
        <import resource="../src/Feature/Checkout/Resources/config/services.xml"/>
    </imports>

    <services>
        <!-- Custom logger to log to var/log/ShipperHQ.log -->
        <service id="shipperhq.logger" class="Monolog\Logger">
            <argument>shipperhq</argument>
            <call method="pushHandler">
                <argument type="service">
                    <service class="Monolog\Handler\StreamHandler">
                        <argument>%kernel.logs_dir%/ShipperHQ.log</argument>
                        <argument>100</argument> <!-- DEBUG level -->
                    </service>
                </argument>
            </call>
        </service>

        <service id="ShipperHQ\WS\Client\WebServiceClient" class="ShipperHQ\WS\Client\WebServiceClient" public="true">
        </service>

        <service id="ShipperHQ\Lib\Helper\Date" class="ShipperHQ\Lib\Helper\Date" public="false">
        </service>

        <service id="ShipperHQ\Lib\Rate\Helper" class="ShipperHQ\Lib\Rate\Helper" public="false">
            <argument type="service" id="ShipperHQ\Lib\Helper\Date"/>
        </service>

        <service id="SHQ\RateProvider\Service\ShippingRateCalculator" public="true">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="shipperhq.logger"/>
        </service>

        <service id="SHQ\RateProvider\Config\ShipperHQClientConfig" public="true">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="SHQ\RateProvider\Service\ShipperHQClient" public="true">
            <argument type="service" id="SHQ\RateProvider\Config\ShipperHQClientConfig"/>
            <argument type="service" id="shipperhq.logger"/>
            <argument type="service" id="ShipperHQ\WS\Client\WebServiceClient"/>
            <argument type="service" id="ShipperHQ\Lib\Rate\Helper"/>
            <argument type="service" id="SHQ\RateProvider\Helper\Mapper"/>
        </service>

        <service id="SHQ\RateProvider\Helper\Mapper">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="shipperhq.logger"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="SHQ\RateProvider\Config\ShipperHQClientConfig"/>
            <argument type="service" id="plugin.repository"/>
            <argument>%kernel.shopware_version%</argument>
        </service>

        <service id="SHQ\RateProvider\Command\ClearShippingRateCacheCommand">
            <argument type="service" id="SHQ\RateProvider\Feature\Checkout\Service\ShippingRateCache"/>
            <tag name="console.command"/>
        </service>

    </services>
</container>
